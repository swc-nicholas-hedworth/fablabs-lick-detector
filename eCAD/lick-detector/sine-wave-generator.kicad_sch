	(text "f = 1/(2*pi*R*C)"
		(exclude_from_sim no)
		(at 149.86 147.32 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "2b534feb-c3be-4d26-88c8-786d5afeb737")
	)
	(text "Gain stage (Av = 3)\nDiode stabalised"
		(exclude_from_sim no)
		(at 119.38 73.66 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "5fc0c246-8c94-4845-976e-2a33d1b3070c")
	)
	(text "Calc: 159.15 kHz \nSim: 157 kHz\nMeas:"
		(exclude_from_sim no)
		(at 149.86 153.67 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "89ecec63-574f-452e-9fd4-166abe9f79c6")
	)
	(text "Op-Amp Selection:\n- GBWP\n	For wein bridge, a gain of exactly 3 is required. The rule of thumb is to choose an op amp with about 50 times higher GBWP than the target frequency.\n	159k * 3 * 50 ~= 24 MHz\n- Slew Rate (SR)\n	2 * pi * f * Vp < SR, where f is the target frequency and Vp is the peak voltage.\n	2 * pi * 159k * 2.5 = 2.5V/us, we will set our target for 10V/us for some headroom.\n- Input Impedance\n	Fet-input Op-amps are preferred (high impedance and bias current), prevents shifting frequency\n\nFinal selection: OPA2365\n- Good supply\n- Actively supported by manufacturer\n- Standard package (easily replaced)"
		(exclude_from_sim no)
		(at 17.78 170.18 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "92cbce1b-fbca-41f5-8d93-879971492b5f")
	)
	(text "Voltage divider followed with filter cap and voltage follower\nAv = 1/10\nCf = 159 kHz"
		(exclude_from_sim no)
		(at 193.04 96.52 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "9ac1a7cb-1110-4fe9-a4b4-3541eea26385")
	)
	(text "Wein Bridge Oscillator (with diode stabalisation)"
		(exclude_from_sim no)
		(at 146.05 49.53 0)
		(effects
			(font
				(size 1.905 1.905)
				(thickness 0.381)
				(bold yes)
			)
